# =============================================================================
# Nova Shop — Next.js Storefront (.env.example)
# Copy to `.env` or `.env.local` and fill in values. Never commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_EXTERNAL_API_URL=http://localhost:5000

# Public site URL — required in production for SEO (sitemap, Open Graph, canonical).
# Local dev: optional; falls back to http://127.0.0.1:$PORT when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# NextAuth (required)
# Generate AUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_SECRET is a legacy alias; prefer AUTH_SECRET for new setups.
# -----------------------------------------------------------------------------
AUTH_SECRET=your_auth_secret_min_32_chars
NEXTAUTH_SECRET=your_auth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth (optional — enable “Sign in with Google”)
# GOOGLE_CLIENT_ID must match NestJS `.env` and Google Cloud Console redirect URIs.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# Stripe (optional — required for checkout)
# Checkout uses server-generated session URLs; no publishable key needed.
# Webhook endpoint: POST /api/stripe/webhook (configure in Stripe Dashboard)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret

# Shared secret for webhook → NestJS order persistence.
# Must match INTERNAL_WEBHOOK_SECRET in Nova-shop-Nestjs `.env`
INTERNAL_WEBHOOK_SECRET=change_me_internal_webhook_secret

# -----------------------------------------------------------------------------
# SEO (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_token

# -----------------------------------------------------------------------------
# Platform (optional — auto-set on Vercel, do not set manually unless needed)
# -----------------------------------------------------------------------------
# VERCEL_URL=
# VERCEL_PROJECT_PRODUCTION_URL=
